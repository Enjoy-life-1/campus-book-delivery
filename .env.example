# 生产务必: FLASK_ENV=production 且 SECRET_KEY 为随机长字符串（不可用默认值）
SECRET_KEY=请替换为随机长字符串
FLASK_ENV=development
# 生产跨域白名单（逗号分隔，留空则开发模式允许任意来源）
# CORS_ORIGINS=https://your-domain.example
# MySQL（Navicat 连接用）
USE_MYSQL=1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=campus_book_delivery

# 或一行连接串（优先于上面分项）
# DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/campus_book_delivery?charset=utf8mb4

# 不用 MySQL 时设 USE_MYSQL=0，走 SQLite campus_book_delivery.db

# Redis 缓存（多进程/Gunicorn 建议开启；不配置则用内存缓存）
# REDIS_URL=redis://127.0.0.1:6379/0

# 阿里云 OSS（可选；不配置则图片存本地 static/uploads/books/）
# USE_OSS=1
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_PUBLIC_BASE=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_PREFIX=books

SMS_WEBHOOK_URL=http://127.0.0.1:8080/sms
SMS_PREFER_WEBHOOK=1

# 阿里云短信（优先于 Webhook；验证码模板变量 ${code}）
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=SMS_xxxxxx
# SMS_NOTIFY_TEMPLATE_CODE=

EMAIL_WEBHOOK_URL=

# RAG 智能找书（默认开启；无 API Key 时用检索摘要模式）
RAG_ENABLED=1
# 阿里云百炼 / 通义（推荐，与 OpenAI 兼容）
# DASHSCOPE_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# EMBEDDING_MODEL=text-embedding-v3
# 或 OpenAI 兼容
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
